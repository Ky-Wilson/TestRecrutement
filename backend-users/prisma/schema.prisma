generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model User {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  birthDate   DateTime
  city        String
  country     String
  avatar      String?
  company     String?
  jobPosition String?
  mobile      String?
  username    String   @unique
  email       String   @unique
  password    String
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}

enum Role {
  USER
  ADMIN
}